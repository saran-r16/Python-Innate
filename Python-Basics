#Bubble Sort

def bubble_sort(arr):
    n=len(arr)
    for i in range(n-1):
        for j in range(n-1):
            if arr[j]>arr[j+1]:
                arr[j],arr[j+1]=arr[j+1],arr[j]
    return arr
arr=list(map(int,input("Enter n number to sort: ").split()))
print(bubble_sort(arr))

#Output

Enter n number to sort: 50 40 30 20 10
[10, 20, 30, 40, 50]

